{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AssetCapsule",
  "type": "object",
  "required": [
    "asset",
    "identity",
    "core_thesis",
    "payoff_drivers",
    "risk_factors",
    "fact_dependencies",
    "information_requirements",
    "hedge_map",
    "invalidation_conditions",
    "execution_constraints"
  ],
  "properties": {
    "asset": {
      "type": "string"
    },
    "identity": {
      "type": "object",
      "additionalProperties": true
    },
    "core_thesis": {
      "type": "object",
      "additionalProperties": true
    },
    "payoff_drivers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "risk_factors": {
      "type": "object",
      "required": ["wanted", "unwanted", "unknown"],
      "properties": {
        "wanted": {
          "type": "array",
          "items": { "type": "string" }
        },
        "unwanted": {
          "type": "array",
          "items": { "type": "string" }
        },
        "unknown": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "fact_dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "information_requirements": {
      "type": "array",
      "items": { "type": "string" }
    },
    "hedge_map": {
      "type": "array",
      "items": {
        "$ref": "./hedge-candidate.schema.json"
      }
    },
    "invalidation_conditions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "execution_constraints": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
